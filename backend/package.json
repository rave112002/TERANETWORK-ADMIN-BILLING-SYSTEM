{
  "name": "template",
  "version": "1.0.0",
  "description": "Template API",
  "type": "module",
  "scripts": {
    "start": "node ./server/bin/www.js",
    "dev": "nodemon ./server/bin/www.js",
    "key:generate": "node ./server/bin/generate-keys.js",
    "pm2:start": "sudo pm2 start ecosystem.config.cjs",
    "pm2:prod": "sudo pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "sudo pm2 reload ecosystem.config.cjs",
    "pm2:stop": "sudo pm2 stop ecosystem.config.cjs",
    "lint": "eslint server/**/*.js?(x)",
    "lint:fix": "eslint server/**/*.js?(x) --fix",
    "format": "prettier --write \"server/**/*.js\"",
    "format:check": "prettier --check \"server/**/*.js\""
  },
  "author": "Raven B",
  "license": "ISC",
  "dependencies": {
    "@paralleldrive/cuid2": "^3.0.4",
    "@sendgrid/mail": "^8.1.6",
    "argon2": "^0.41.1",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "canvas": "^3.2.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "html-entities": "^2.6.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "mime": "^4.1.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.48",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.14.0",
    "opossum": "^9.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^9.0.1",
    "sanitize-html": "^2.15.0",
    "sequelize": "^6.37.7",
    "sharp": "^0.34.1",
    "uniqid": "^5.4.0",
    "uuid": "^13.0.0",
    "validator": "^13.15.20",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xss": "^1.0.15",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.9",
    "prettier": "^3.7.4",
    "sequelize-cli": "^6.6.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
