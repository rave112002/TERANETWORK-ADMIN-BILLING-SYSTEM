###############################
# APPLICATION
###############################
NODE_ENV=development
PORT=3000

###############################
# DATABASE (REQUIRED)
###############################
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_DATABASE=your_database_name

# Database pool configuration (optional - defaults shown)
DB_POOL_SIZE=10
DB_CONNECT_TIMEOUT=10000

###############################
# JWT AUTHENTICATION (REQUIRED)
###############################
jwtAuthPath=./auth-keys
ISSUER=your-app-name
AUDIENCE=your-app-users
EXPIRY=24h

###############################
# SECURITY (REQUIRED)
###############################
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=CHANGE_THIS_generate_a_random_64_character_secret_here_do_not_use_this_example_value
LOG_SALT=CHANGE_THIS_generate_a_random_32_character_salt_here_do_not_use_this_example_value

# Optional: API key for public endpoints
SECRET_KEY=

###############################
# ENCRYPTION (OPTIONAL)
###############################
# AES-256 encryption key (if using crypto.js)
cryptoKey=

###############################
# SSL/TLS (OPTIONAL)
###############################
# Path to SSL certificate directory (enables HTTPS)
certPath=

###############################
# CORS (OPTIONAL)
###############################
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOW_CROSS_SITE_CSRF
COOKIE_SECURE
###############################
# REDIS / WORKERS (OPTIONAL)
###############################
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
ENABLE_EMAIL_WORKER=false

###############################
# RATE LIMITING (OPTIONAL)
###############################
# Store type: 'memory' (single instance) | 'redis' (clustered) | 'mysql' (clustered)
# For production with PM2 cluster mode, use 'redis' or 'mysql'
RATE_LIMIT_STORE=memory
RATE_LIMIT_KEY_PREFIX=rl

# Redis-specific (only if RATE_LIMIT_STORE=redis)
RATE_LIMIT_REDIS_HOST=localhost
RATE_LIMIT_REDIS_PORT=6379
RATE_LIMIT_REDIS_PASSWORD=

# Profile overrides (optional - defaults shown)
# API: General requests
RATE_LIMIT_API_POINTS=100
RATE_LIMIT_API_DURATION=900
RATE_LIMIT_API_BLOCK=0

# Auth: Login/Register (stricter)
RATE_LIMIT_AUTH_POINTS=10
RATE_LIMIT_AUTH_DURATION=900
RATE_LIMIT_AUTH_BLOCK=900

# Upload: File uploads
RATE_LIMIT_UPLOAD_POINTS=20
RATE_LIMIT_UPLOAD_DURATION=3600
RATE_LIMIT_UPLOAD_BLOCK=0

# Password Reset (very strict)
RATE_LIMIT_PWRESET_POINTS=3
RATE_LIMIT_PWRESET_DURATION=3600
RATE_LIMIT_PWRESET_BLOCK=3600

# CSRF Token generation
RATE_LIMIT_CSRF_POINTS=30
RATE_LIMIT_CSRF_DURATION=900
RATE_LIMIT_CSRF_BLOCK=0

# Strict: Sensitive operations
RATE_LIMIT_STRICT_POINTS=5
RATE_LIMIT_STRICT_DURATION=3600
RATE_LIMIT_STRICT_BLOCK=7200

###############################
# THIRD-PARTY SERVICES (OPTIONAL)
###############################
SENDGRID_API_KEY=

###############################
# FILE VALIDATION (OPTIONAL)
###############################
STRICT_FILE_VALIDATION=true
SCAN_MALWARE_PATTERNS=true
ALLOW_PRIVATE_IPS=false
EXTERNAL_API_WHITELIST=api.example.com

###############################
# TIMEZONE (OPTIONAL)
###############################
# Display timezone (storage is always UTC)
TIMEZONE=Asia/Manila
